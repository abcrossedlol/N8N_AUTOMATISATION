    {
      "parameters": {
        "url": "=https://services.nvd.nist.gov/rest/json/cves/2.0?pubStartDate={{$now.minus(1,'day').startOf('day').toISO()}}&pubEndDate={{$now.startOf('day').toISO()}}",
        "options": {
          "timeout": 60000
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
