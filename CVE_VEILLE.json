        -992,
        256
      ],
      "id": "465e0af3-f94d-4c31-ab96-a7943a33a6d8",
      "name": "GET_CVE",
      "retryOnFail": false,
      "waitBetweenTries": 5000
    },
    {
      "parameters": {
        "jsCode": "const items = $input.first().json.vulnerabilities || [];\n\nconst filtered = items.filter(v => {\n  const metrics = v.cve?.metrics?.cvssMetricV31 || v.cve?.metrics?.cvssMetricV30 || [];\n  if (metrics.length === 0) return false;\n  const score = metrics[0].cvssData?.baseScore || 0;\n  return score >= 7;\n});\n\nreturn filtered.map(v => {\n  const metrics = v.cve?.metrics?.cvssMetricV31 || v.cve?.metrics?.cvssMetricV30 || [];\n  const score = metrics[0]?.cvssData?.baseScore || 'N/A';\n  const severity = metrics[0]?.cvssData?.baseSeverity || 'N/A';\n  const desc = v.cve?.descriptions?.find(d => d.lang === 'en')?.value || 'No description';\n  const id = v.cve?.id || 'Unknown';\n\n  return {\n    json: {\n      id,\n      score,\n      severity,\n      description: desc.substring(0, 300),\n      url: `https://nvd.nist.gov/vuln/detail/${id}`\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -784,
        256
      ],
      "id": "b05a5eb2-58c2-4d1d-8a7e-578c808120c6",
      "name": "FILTRE_CVSS"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nconst technos = {\n  windows: ['windows', 'active directory', 'microsoft', 'win32', 'mshtml', 'outlook', 'office'],\n  linux: ['linux', 'debian', 'ubuntu', 'rhel', 'centos', 'kernel', 'gnu'],\n  apache: ['apache', 'nginx', 'http server', 'tomcat', 'httpd'],\n  cisco: ['cisco', 'ios', 'nx-os', 'asa', 'firepower', 'catalyst']\n};\n\nconst emojis = { windows: '🪟', linux: '🐧', apache: '🌐', cisco: '🔧', autres: '❓' };\n\n// Classe chaque CVE dans une ou plusieurs technos\nconst buckets = { windows: [], linux: [], apache: [], cisco: [] };\n\nfor (const item of items) {\n  const desc = (item.json.description || '').toLowerCase();\n  const id = (item.json.id || '').toLowerCase();\n  const text = desc + ' ' + id;\n\n  for (const [techno, keywords] of Object.entries(technos)) {\n    if (keywords.some(kw => text.includes(kw))) {\n      buckets[techno].push(item.json);\n    }\n  }\n}\n\nconst results = [];\n\n// Formate un message par techno\nfor (const [techno, cves] of Object.entries(buckets)) {\n  if (cves.length === 0) continue;\n\n  const top = cves.slice(0, 5);\n  const lines = top.map(cve => {\n    const emoji = cve.score >= 9 ? '🔴' : '🟠';\n    const shortDesc = cve.description.substring(0, 100);\n    return `${emoji} **${cve.id}** (${cve.score} - ${cve.severity})\\n${shortDesc}...\\n${cve.url}`;\n  });\n\n  const content = `${emojis[techno]} **Veille CVE ${techno.toUpperCase()} du ${new Date().toLocaleDateString('fr-FR')}** (${cves.length} CVE)\\n\\n${lines.join('\\n\\n')}`.substring(0, 1990);\n\n  results.push({ json: { techno, content } });\n}\n\n// CVE qui n'ont matché aucune techno → salon #cve-autres\nconst matchedIds = Object.values(buckets).flat().map(cve => cve.id);\nconst autres = items.filter(item => !matchedIds.includes(item.json.id));\n\nif (autres.length > 0) {\n  const top = autres.slice(0, 5);\n  const lines = top.map(cve => {\n    const emoji = cve.json.score >= 9 ? '🔴' : '🟠';\n    const shortDesc = cve.json.description.substring(0, 100);\n    return `${emoji} **${cve.json.id}** (${cve.json.score} - ${cve.json.severity})\\n${shortDesc}...\\n${cve.json.url}`;\n  });\n\n  const content = `${emojis['autres']} **Veille CVE AUTRES du ${new Date().toLocaleDateString('fr-FR')}** (${autres.length} CVE)\\n\\n${lines.join('\\n\\n')}`.substring(0, 1990);\n\n  results.push({ json: { techno: 'autres', content } });\n}\n\n// Aucune CVE du tout\nif (results.length === 0) {\n  return [{ json: { techno: 'none', content: '' } }];\n}\nconsole.log('TECHNOS:', results.map(r => r.json.techno));\nreturn results;"
      },
