    {
      "parameters": {
        "jsCode": "const reponse = $input.first().json.choices?.[0]?.message?.content || 'Désolé, je ne peux pas répondre.';\nconst question = $('FILTRE_SSI').first().json.question;\n\nconst content = `🤖 **SSI-Bot**\\n\\n❓ **Question :** ${question}\\n\\n💬 **Réponse :**\\n${reponse}`.substring(0, 1990);\n\nreturn [{ json: { content } }];"
      },
