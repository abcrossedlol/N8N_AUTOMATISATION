        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"llama-3.1-8b-instant\",\n  \"max_tokens\": 500,\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"Tu es un expert en cybersécurité et SSI. Tu réponds de façon claire, concise et professionnelle en français. Tu connais parfaitement les normes ISO 27001, EBIOS RM, DORA, et les bonnes pratiques SSI.\"\n    },\n    {\n      \"role\": \"user\", \n      \"content\": \"={{ $json.question }}\"\n    }\n  ]\n}",
        "options": {}
      },
