    {
      "parameters": {
        "jsCode": "const messages = $input.all().map(item => item.json);\n\nconsole.log('MESSAGES:', JSON.stringify(messages.map(m => ({ id: m.id, content: m.content }))));\n\nconst lastProcessedId = '0';\n\nconst toProcess = messages.filter(msg => \n  msg && msg.content && msg.content.startsWith('!ssi ') && \n  !msg.author?.bot\n);\n\nif (toProcess.length === 0) return [];\n\nconst latestId = toProcess[0].id;\n\nreturn toProcess.map(msg => ({\n  json: {\n    question: msg.content.replace('!ssi ', '').trim(),\n    messageId: msg.id,\n    latestId\n  }\n}));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
